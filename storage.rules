rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Archivos de presskits organizados por uid:
    // presskits/{userId}/{folder}/{fileName}
    match /presskits/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Denegar cualquier otra ruta de Storage por defecto.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
