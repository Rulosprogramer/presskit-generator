# ─── Cliente (Vite, se exponen al navegador con prefijo VITE_) ───────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_GEMINI_API_KEY=

# ─── Servidor (funciones /api en Vercel — NUNCA con prefijo VITE_) ───────────
# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-...            # Access token de tu app de Mercado Pago
MP_CURRENCY=USD                        # Moneda (USD, COP, etc. según tu cuenta)
MP_PRICE_ONCE=4.99                     # Pago único (descarga + enlace 20 días)
MP_PRICE_ANNUAL=14.99                  # Suscripción anual

# Service account de Firebase (JSON de una sola línea o en base64).
# Genérala en: Firebase Console > Configuración del proyecto > Cuentas de servicio > Generar nueva clave privada.
FIREBASE_SERVICE_ACCOUNT=

# Opcional: fuerza la URL base usada en success_url/cancel_url.
# Si se omite, se deduce del host de la petición (recomendado en Vercel).
APP_URL=
